# MongoDB connection (Atlas or local)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT signing secret for admin session cookie (min 32 characters; use a long random string)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional: used only by `npm run seed:admin`
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_MOBILE=+10000000000
SEED_ADMIN_PASSWORD=change-me-in-production
